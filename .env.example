# PostgreSQL connection (port 5434 for local dev via docker-compose.dev.yml)
DATABASE_URL=postgresql://vibecoder:vibecoder_dev@localhost:5434/vibecoder

# JWT secret for auth tokens — use a random 32+ char string in production
JWT_SECRET=change-me-in-production

# Initial admin account (created on first boot)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# PostgreSQL password (used by docker-compose.yml for the postgres container)
POSTGRES_PASSWORD=vibecoder_dev

# Domain for Caddy TLS (production only)
VIBECODER_DOMAIN=localhost
